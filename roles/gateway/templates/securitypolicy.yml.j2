apiVersion: gateway.envoyproxy.io/v1alpha1
kind: SecurityPolicy
metadata:
  name: {{ gateway_route_name }}
  namespace: {{ gateway_route_namespace }}
spec:
  targetRef:
    group: gateway.networking.k8s.io
    kind: HTTPRoute
    name: {{ gateway_route_name }}
  cors:
    allowOrigins:
{% for origin in gateway_route_config.security_policy_cors_allow_origins %}
      - "{{ origin }}"
{% endfor %}
    allowMethods:
{% for method in gateway_route_config.security_policy_cors_allow_methods | default(_gateway_route_default_cors_allow_methods) %}
      - {{ method }}
{% endfor %}
    allowHeaders:
{% for header in gateway_route_config.security_policy_cors_allow_headers | default(_gateway_route_default_cors_allow_headers) %}
      - "{{ header }}"
{% endfor %}
    exposeHeaders:
      - "*"
