diff --git a/cinder/templates/cephblockpool.yaml b/cinder/templates/cephblockpool.yaml
new file mode 100644
index 0000000..ad6b598
--- /dev/null
+++ b/cinder/templates/cephblockpool.yaml
@@ -0,0 +1,52 @@
+{{/*
+Licensed under the Apache License, Version 2.0 (the "License");
+you may not use this file except in compliance with the License.
+You may obtain a copy of the License at
+
+   http://www.apache.org/licenses/LICENSE-2.0
+
+Unless required by applicable law or agreed to in writing, software
+distributed under the License is distributed on an "AS IS" BASIS,
+WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+See the License for the specific language governing permissions and
+limitations under the License.
+*/}}
+
+{{- range $pool_name, $pool_config := .Values.conf.ceph.pools }}
+{{- if $pool_config.erasure_coded }}
+{{- $data_pool_name := printf "%s.data" $pool_name }}
+{{- if $pool_config.erasure_coded.data_pool_name }}
+{{- $data_pool_name = $pool_config.erasure_coded.data_pool_name }}
+{{- end }}
+---
+apiVersion: ceph.rook.io/v1
+kind: CephBlockPool
+metadata:
+  name: {{ $data_pool_name }}
+  namespace: {{ $.Release.Namespace }}
+  annotations:
+    helm.sh/resource-policy: keep
+spec:
+  failureDomain: {{ $pool_config.erasure_coded.failure_domain }}
+  erasureCoded:
+    dataChunks: {{ $pool_config.erasure_coded.k }}
+    codingChunks: {{ $pool_config.erasure_coded.m }}
+  {{- if $pool_config.erasure_coded.device_class }}
+  deviceClass: {{ $pool_config.erasure_coded.device_class }}
+  {{- end }}
+---
+apiVersion: ceph.rook.io/v1
+kind: CephBlockPool
+metadata:
+  name: {{ $pool_name }}
+  namespace: {{ $.Release.Namespace }}
+  annotations:
+    helm.sh/resource-policy: keep
+spec:
+  failureDomain: {{ $pool_config.erasure_coded.failure_domain }}
+  replicated:
+    size: {{ $pool_config.metadata.replication }}
+  parameters:
+    crush_rule: {{ $pool_config.metadata.crush_rule }}
+{{- end }}
+{{- end }}
diff --git a/cinder/values.yaml b/cinder/values.yaml
index 9937584..c4ef42f 100644
--- a/cinder/values.yaml
+++ b/cinder/values.yaml
@@ -833,6 +833,37 @@ conf:
         crush_rule: replicated_rule
         chunk_size: 8
         app_name: cinder-volume
+
+    # Erasure-coded (EC) pool support:
+    # Any pool with an "erasure_coded" key automatically gets two
+    # CephBlockPool CRDs created via Rook:
+    #   - A replicated metadata pool named after the pool key
+    #   - An erasure-coded data pool named "<pool_key>.data" by default
+    #
+    # The data pool name can be overridden with "data_pool_name".
+    #
+    # pools:
+    #   cinder.volumes.ec:
+    #     app_name: cinder-volume
+    #     erasure_coded:
+    #       k: 4                       # data chunks
+    #       m: 2                       # coding chunks
+    #       device_class: hdd          # optional: target device class
+    #       failure_domain: host
+    #       data_pool_name: my-custom-data-pool  # optional: override
+    #     metadata:
+    #       replication: 3
+    #       crush_rule: replicated_rule
+    #
+    # Then configure the backend to reference the derived names:
+    #
+    # backends:
+    #   rbd_ec:
+    #     volume_driver: cinder.volume.drivers.rbd.RBDDriver
+    #     rbd_pool: cinder.volumes.ec            # metadata pool (replicated)
+    #     rbd_data_pool: cinder.volumes.ec.data  # data pool (auto-derived)
+    #     rbd_user: cinder-ec
+    #     ...
   cinder:
     DEFAULT:
       state_path: /var/lib/cinder
